{
  "name": "@robin7331/papyrus-cli",
  "version": "0.1.5",
  "private": false,
  "description": "Convert PDF to markdown or text with the OpenAI Agents SDK",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robin7331/papyrus-cli.git"
  },
  "bugs": {
    "url": "https://github.com/robin7331/papyrus-cli/issues"
  },
  "license": "MIT",
  "keywords": [
    "pdf",
    "markdown",
    "text",
    "openai",
    "cli",
    "ocr",
    "document-conversion"
  ],
  "type": "module",
  "bin": {
    "papyrus": "./dist/cli.js",
    "papyrus-cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@openai/agents": "^0.5.3",
    "commander": "^14.0.0",
    "dotenv": "^17.3.1",
    "openai": "^6.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
